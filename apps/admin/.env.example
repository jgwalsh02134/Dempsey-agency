# Direct API URL (optional). If unset in development, requests use Vite proxy to avoid CORS.
# Example production build: VITE_API_BASE_URL=https://api.dempsey.agency
# VITE_API_BASE_URL=https://api.dempsey.agency

# Dev-only: override proxy target (default https://api.dempsey.agency)
# VITE_API_PROXY_TARGET=https://api.dempsey.agency
