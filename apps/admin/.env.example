# --- Local development ---
# Leave unset to use Vite dev proxy (/api → api.dempsey.agency).
# Or set to call the API directly (requires CORS on the API for localhost).
# VITE_API_BASE_URL=https://api.dempsey.agency

# Optional: proxy target when VITE_API_BASE_URL is unset (default https://api.dempsey.agency)
# VITE_API_PROXY_TARGET=https://api.dempsey.agency

# --- Production build (see .env.production.example) ---
# Cloudflare Pages: set VITE_API_BASE_URL in the dashboard (Production + Preview).
