# Dev-only: Vite dev-server proxy target. The app uses RELATIVE /api paths
# locally, which Vite rewrites to this target.
VITE_API_PROXY_TARGET=http://localhost:3100

# Production (and any non-dev environment): absolute origin of workspace-api.
# When set, the client prepends this base to every /api/... request instead
# of resolving it against the frontend origin.
# Example:
# VITE_WORKSPACE_API_URL=https://workspace-api.dempsey.agency
