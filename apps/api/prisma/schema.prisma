generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  AGENCY_OWNER
  AGENCY_ADMIN
  STAFF
  CLIENT_ADMIN
  CLIENT_USER
}

enum OrganizationType {
  AGENCY
  CLIENT
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
}

enum CreativeType {
  PRINT
  DIGITAL
}

enum SubmissionStatus {
  SUBMITTED
  APPROVED
  REVISION_REQUESTED
}

enum AccountRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MediaType {
  PRINT
  DIGITAL
  EMAIL
  OTHER
}

enum PlacementStatus {
  DRAFT
  BOOKED
  LIVE
  COMPLETED
  CANCELLED
}

enum PricingModel {
  CPM
  VCPM
  CPC
  CPCV
  FLAT
  COLUMN_INCH
  PER_LINE
  OTHER
}

enum AuditAction {
  USER_CREATED
  ROLE_CHANGED
  USER_DEACTIVATED
  MEMBERSHIP_REMOVED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships          OrganizationMembership[]
  auditLogsAsActor     AuditLog[]             @relation("AuditActor")
  auditLogsAsTarget    AuditLog[]             @relation("AuditTarget")
  uploadedDocuments    Document[]
  createdCampaigns     Campaign[]
  createdInvoices      Invoice[]
  submissions              CreativeSubmission[]
  reviewedAccountRequests  AccountRequest[]
  createdInvites           Invite[]           @relation("InviteCreator")
  passwordResets           PasswordReset[]
}

model Organization {
  id        String           @id @default(cuid())
  name      String
  type      OrganizationType
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  memberships         OrganizationMembership[]
  agencyRelationships AgencyClientRelationship[] @relation("AgencyOrg")
  clientRelationships AgencyClientRelationship[] @relation("ClientOrg")
  documents           Document[]
  campaigns           Campaign[]
  invoices            Invoice[]
  submissions         CreativeSubmission[]
  invites             Invite[]
}

model OrganizationMembership {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           Role
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
}

model AgencyClientRelationship {
  id        String   @id @default(cuid())
  agencyId  String
  clientId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agency Organization @relation("AgencyOrg", fields: [agencyId], references: [id])
  client Organization @relation("ClientOrg", fields: [clientId], references: [id])

  @@unique([agencyId, clientId])
}

model Document {
  id             String   @id @default(cuid())
  organizationId String
  title          String
  description    String?
  filename       String
  mimeType       String
  sizeBytes      Int
  storageKey     String
  uploadedById   String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])

  @@index([organizationId, createdAt])
}

model Campaign {
  id             String         @id @default(cuid())
  organizationId String
  title          String
  description    String?
  status         CampaignStatus @default(ACTIVE)
  budgetCents    Int?
  startDate      DateTime?
  endDate        DateTime?
  createdById    String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  createdBy    User         @relation(fields: [createdById], references: [id])
  submissions  CreativeSubmission[]
  placements   Placement[]

  @@index([organizationId, status])
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  title          String
  description    String?
  amountCents    Int
  currency       String        @default("USD")
  status         InvoiceStatus @default(PENDING)
  invoiceDate    DateTime
  dueDate        DateTime?
  createdById    String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  createdBy    User         @relation(fields: [createdById], references: [id])

  @@index([organizationId, status])
}

model CreativeSubmission {
  id             String           @id @default(cuid())
  campaignId     String
  organizationId String
  title          String
  description    String?
  creativeType   CreativeType
  filename       String
  mimeType       String
  sizeBytes      Int
  storageKey     String
  status         SubmissionStatus @default(SUBMITTED)
  reviewNote     String?
  submittedById  String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  campaign     Campaign     @relation(fields: [campaignId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  submittedBy  User         @relation(fields: [submittedById], references: [id])

  @@index([campaignId, status])
  @@index([organizationId])
}

model AccountRequest {
  id           String               @id @default(cuid())
  email        String
  name         String
  company      String
  message      String?
  status       AccountRequestStatus @default(PENDING)
  reviewedById String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  reviewedBy User? @relation(fields: [reviewedById], references: [id])
  invites    Invite[]

  @@index([status])
  @@index([createdAt])
  @@index([email])
}

model Invite {
  id               String    @id @default(cuid())
  email            String
  token            String    @unique
  organizationId   String
  role             Role      @default(CLIENT_USER)
  accountRequestId String?
  expiresAt        DateTime
  usedAt           DateTime?
  createdById      String
  createdAt        DateTime  @default(now())

  organization   Organization    @relation(fields: [organizationId], references: [id])
  createdBy      User            @relation("InviteCreator", fields: [createdById], references: [id])
  accountRequest AccountRequest? @relation(fields: [accountRequestId], references: [id])

  @@index([email])
  @@index([expiresAt])
}

model PasswordReset {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model Publisher {
  id           String   @id @default(cuid())
  name         String
  city         String?
  state        String?
  websiteUrl   String?
  logoUrl      String?
  contactEmail String?
  circulation  Int?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  inventory Inventory[]
}

model Inventory {
  id           String       @id @default(cuid())
  publisherId  String
  name         String
  mediaType    MediaType
  pricingModel PricingModel @default(FLAT)
  rateCents    Int?
  description  String?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  publisher  Publisher   @relation(fields: [publisherId], references: [id])
  placements Placement[]

  @@index([publisherId])
}

model Placement {
  id             String          @id @default(cuid())
  campaignId     String
  inventoryId    String
  name           String
  status         PlacementStatus @default(DRAFT)
  grossCostCents Int
  netCostCents   Int?
  quantity       Int?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  campaign  Campaign  @relation(fields: [campaignId], references: [id])
  inventory Inventory @relation(fields: [inventoryId], references: [id])

  @@index([campaignId])
  @@index([inventoryId])
}

/// Append-only security audit trail (admin / membership actions).
model AuditLog {
  id             String      @id @default(cuid())
  action         AuditAction
  actorUserId    String?
  targetUserId   String?
  organizationId String?
  metadata       Json?
  createdAt      DateTime    @default(now())

  actorUser  User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  targetUser User? @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([organizationId])
  @@index([actorUserId])
}
