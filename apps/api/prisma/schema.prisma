generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  AGENCY_OWNER
  AGENCY_ADMIN
  STAFF
  CLIENT_ADMIN
  CLIENT_USER
}

enum OrganizationType {
  AGENCY
  CLIENT
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
}

enum CreativeType {
  PRINT
  DIGITAL
  MASTER_ASSET
}

enum SubmissionStatus {
  UPLOADED
  VALIDATION_FAILED
  UNDER_REVIEW
  NEEDS_RESIZING
  READY_FOR_PUBLISHER
  PUSHED
}

enum AccountRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MediaType {
  PRINT
  DIGITAL
  EMAIL
  OTHER
}

enum PlacementStatus {
  DRAFT
  BOOKED
  LIVE
  COMPLETED
  CANCELLED
}

/// Client-side acknowledgment state for a placement. Orthogonal to the
/// operational PlacementStatus above — agencies control placement status;
/// clients control this response. Two-state v1; additional states (e.g.,
/// FLAGGED) can be added later without breaking existing rows.
enum PlacementClientResponse {
  PENDING_CLIENT_REVIEW
  CLIENT_APPROVED
}

enum PricingModel {
  CPM
  VCPM
  CPC
  CPCV
  FLAT
  COLUMN_INCH
  PER_LINE
  OTHER
}

enum AuditAction {
  USER_CREATED
  ROLE_CHANGED
  USER_DEACTIVATED
  MEMBERSHIP_REMOVED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships          OrganizationMembership[]
  auditLogsAsActor     AuditLog[]             @relation("AuditActor")
  auditLogsAsTarget    AuditLog[]             @relation("AuditTarget")
  uploadedDocuments    Document[]
  createdCampaigns     Campaign[]
  createdInvoices      Invoice[]
  submissions              CreativeSubmission[]
  reviewedAccountRequests  AccountRequest[]
  createdInvites           Invite[]           @relation("InviteCreator")
  passwordResets           PasswordReset[]
  notifications            Notification[]
}

model Organization {
  id        String           @id @default(cuid())
  name      String
  type      OrganizationType
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  memberships         OrganizationMembership[]
  agencyRelationships AgencyClientRelationship[] @relation("AgencyOrg")
  clientRelationships AgencyClientRelationship[] @relation("ClientOrg")
  documents           Document[]
  campaigns           Campaign[]
  invoices            Invoice[]
  submissions         CreativeSubmission[]
  invites             Invite[]
}

model OrganizationMembership {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           Role
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
}

model AgencyClientRelationship {
  id        String   @id @default(cuid())
  agencyId  String
  clientId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agency Organization @relation("AgencyOrg", fields: [agencyId], references: [id])
  client Organization @relation("ClientOrg", fields: [clientId], references: [id])

  @@unique([agencyId, clientId])
}

/// Categorization for uploaded documents. Applied at the document level so
/// the portal can group proofs/invoices/etc. and surface an Invoices view
/// without requiring campaign-level linking. Additional categories can be
/// appended without breaking existing rows (defaults to OTHER).
enum DocumentCategory {
  PROOF
  INVOICE
  INSERTION_ORDER
  CONTRACT
  CREATIVE_ASSET
  OTHER
}

model Document {
  id             String           @id @default(cuid())
  organizationId String
  title          String
  description    String?
  filename       String
  mimeType       String
  sizeBytes      Int
  storageKey     String
  category       DocumentCategory @default(OTHER)
  uploadedById   String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])

  @@index([organizationId, createdAt])
  @@index([organizationId, category])
}

model Campaign {
  id             String         @id @default(cuid())
  organizationId String
  title          String
  description    String?
  status         CampaignStatus @default(ACTIVE)
  budgetCents    Int?
  startDate      DateTime?
  endDate        DateTime?
  createdById    String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  createdBy    User         @relation(fields: [createdById], references: [id])
  submissions    CreativeSubmission[]
  placements     Placement[]
  publisherLinks CampaignPublisher[]

  @@index([organizationId, status])
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  title          String
  description    String?
  amountCents    Int
  currency       String        @default("USD")
  status         InvoiceStatus @default(PENDING)
  invoiceDate    DateTime
  dueDate        DateTime?
  createdById    String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  createdBy    User         @relation(fields: [createdById], references: [id])

  @@index([organizationId, status])
}

model CreativeSubmission {
  id                String           @id @default(cuid())
  campaignId        String
  organizationId    String
  title             String
  description       String?
  creativeType      CreativeType
  filename          String
  mimeType          String
  sizeBytes         Int
  storageKey        String
  status            SubmissionStatus @default(UPLOADED)
  reviewNote        String?
  placementId       String?
  // Basic revision chain. parentSubmissionId points at the ROOT submission
  // in the chain (not the immediately-previous revision) so each row has
  // O(1) access to its siblings. version is 1 for the original, 2+ for
  // subsequent client-uploaded revisions.
  parentSubmissionId String?
  version            Int              @default(1)
  widthPx           Int?
  heightPx          Int?
  dpi               Int?
  colorSpace        String?
  validationSummary Json?
  submittedById     String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  campaign     Campaign     @relation(fields: [campaignId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  submittedBy  User         @relation(fields: [submittedById], references: [id])
  placement    Placement?   @relation(fields: [placementId], references: [id], onDelete: SetNull)
  parent       CreativeSubmission?  @relation("SubmissionRevisions", fields: [parentSubmissionId], references: [id], onDelete: SetNull)
  revisions    CreativeSubmission[] @relation("SubmissionRevisions")

  @@index([campaignId, status])
  @@index([organizationId])
  @@index([parentSubmissionId])
}

model AccountRequest {
  id           String               @id @default(cuid())
  email        String
  name         String
  company      String
  message      String?
  status       AccountRequestStatus @default(PENDING)
  reviewedById String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  reviewedBy User? @relation(fields: [reviewedById], references: [id])
  invites    Invite[]

  @@index([status])
  @@index([createdAt])
  @@index([email])
}

model Invite {
  id               String    @id @default(cuid())
  email            String
  token            String    @unique
  organizationId   String
  role             Role      @default(CLIENT_USER)
  accountRequestId String?
  expiresAt        DateTime
  usedAt           DateTime?
  createdById      String
  createdAt        DateTime  @default(now())

  organization   Organization    @relation(fields: [organizationId], references: [id])
  createdBy      User            @relation("InviteCreator", fields: [createdById], references: [id])
  accountRequest AccountRequest? @relation(fields: [accountRequestId], references: [id])

  @@index([email])
  @@index([expiresAt])
}

model PasswordReset {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model Publisher {
  id               String   @id @default(cuid())
  // Identity
  name             String
  parentCompany    String?
  publicationType  String?
  frequency        String?
  circulation      Int?
  yearEstablished  Int?
  isActive         Boolean  @default(true)
  // Location
  streetAddress    String?
  streetAddress2   String?
  city             String?
  state            String?
  zipCode          String?
  county           String?
  country          String?
  latitude         Float?
  longitude        Float?
  geocodeStatus    String?   // OK | FAILED | NO_ADDRESS
  geocodedAt       DateTime?
  // DMA (Designated Market Area) — Nielsen-style market identifiers.
  // Both nullable; no enum (DMA list is large + externally maintained).
  // TODO: Backfill dmaName and dmaCode from publisher DMA dataset
  dmaName          String?
  dmaCode          String?
  // Contacts
  phone            String?
  officeHours      String?
  contactName      String?
  contactTitle     String?
  // Website / reference links
  websiteUrl       String?
  logoUrl          String?
  rateCardUrl      String?
  mediaKitUrl      String?
  adSpecsUrl       String?
  // Emails
  generalEmail     String?
  transactionEmail String?
  corporateEmail   String?
  editorialEmail   String?
  advertisingEmail String?
  billingEmail     String?
  // Other
  notes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventory     Inventory[]
  campaignLinks CampaignPublisher[]

  @@index([name])
  @@index([state, city])
}

/// Many-to-many: which publishers a client has selected for a given campaign.
/// Drives the campaign-scoped publisher map in the portal.
model CampaignPublisher {
  id          String   @id @default(cuid())
  campaignId  String
  publisherId String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign  Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  publisher Publisher @relation(fields: [publisherId], references: [id], onDelete: Cascade)

  @@unique([campaignId, publisherId])
  @@index([campaignId])
  @@index([publisherId])
}

model Inventory {
  id           String       @id @default(cuid())
  publisherId  String
  name         String
  mediaType    MediaType
  pricingModel PricingModel @default(FLAT)
  rateCents    Int?
  description  String?
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  publisher  Publisher   @relation(fields: [publisherId], references: [id])
  placements Placement[]

  @@index([publisherId])
}

model Placement {
  id             String          @id @default(cuid())
  campaignId     String
  inventoryId    String
  name           String
  status         PlacementStatus @default(DRAFT)
  grossCostCents Int
  netCostCents   Int?
  quantity       Int?
  notes          String?
  // Client acknowledgment — defaults to PENDING_CLIENT_REVIEW on create.
  // Orthogonal to `status`; does not affect booking/live state.
  clientResponse     PlacementClientResponse @default(PENDING_CLIENT_REVIEW)
  clientResponseNote String?
  clientRespondedAt  DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  campaign    Campaign             @relation(fields: [campaignId], references: [id])
  inventory   Inventory            @relation(fields: [inventoryId], references: [id])
  submissions CreativeSubmission[]

  @@index([campaignId])
  @@index([inventoryId])
}

/// Per-user notification row for lightweight in-app/email awareness of key
/// workflow events. Persistence-only for v1; delivery channels (email, in-app
/// center, push) can read this table without changing upstream call sites.
/// `relatedId` is an opaque pointer into the originating domain row
/// (submission, placement, document) — no enforced FK, so a target can be
/// deleted without breaking history.
enum NotificationType {
  CREATIVE_REVISION_REQUESTED
  CREATIVE_REVISION_UPLOADED
  PLACEMENT_AWAITING_APPROVAL
  PLACEMENT_APPROVED_BY_CLIENT
  NEW_INVOICE_UPLOADED
  NEW_PROOF_UPLOADED
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  relatedId String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

/// Append-only security audit trail (admin / membership actions).
model AuditLog {
  id             String      @id @default(cuid())
  action         AuditAction
  actorUserId    String?
  targetUserId   String?
  organizationId String?
  metadata       Json?
  createdAt      DateTime    @default(now())

  actorUser  User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  targetUser User? @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([organizationId])
  @@index([actorUserId])
}
