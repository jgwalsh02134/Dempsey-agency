DATABASE_URL=postgresql://user:password@localhost:5432/dempsey
PORT=3001
NODE_ENV=development

# CORS — comma-separated browser origins (preferred). CORS_ORIGIN also works (single or comma list).
# Local: one dev origin. Production: list every site that calls the API.
# CORS_ORIGINS=https://dempsey.agency,https://portal.dempsey.agency,https://admin.dempsey.agency
CORS_ORIGIN=http://localhost:5173

# Auth — generate a real secret for production (e.g. openssl rand -base64 48)
JWT_SECRET=unsafe-dev-secret
JWT_EXPIRES_IN=7d

# --- Object storage (S3-compatible: Cloudflare R2, AWS S3, MinIO) ---
# Required for document upload/download. Omit to start the API without document support.
# S3_BUCKET=dempsey-documents
# S3_REGION=auto
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key

# --- Transactional email (Resend) ---
# Optional. When RESEND_API_KEY is unset, the API still runs and persists
# in-app notifications; outbound email is a logged no-op. EMAIL_FROM must be
# a Resend-verified sender. APP_PORTAL_URL / APP_ADMIN_URL are used to build
# CTA links in outgoing emails.
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM=Dempsey Agency <notifications@example.com>
# APP_PORTAL_URL=https://portal.dempsey.agency
# APP_ADMIN_URL=https://admin.dempsey.agency

# --- Bootstrap only (used by `npm run seed` / `prisma db seed` — NOT read by the API process) ---
# Do not set these on Railway or any production runtime. Remove or leave unset after initial setup;
# rotate the seeded password via POST /api/v1/auth/change-password, then delete weak passwords from docs.
# SEED_EMAIL=admin@dempsey.agency
# SEED_PASSWORD=changeme123
# SEED_ORG_NAME=Dempsey Agency
