# Workspace database. MUST be a dedicated database, not shared with admin/portal.
WORKSPACE_DATABASE_URL=postgres://user:password@localhost:5432/adsell_workspace

PORT=3100
NODE_ENV=development

# Comma-separated list of allowed origins (workspace-web only).
# When using credentialed cookies, this MUST list the exact frontend origin(s).
CORS_ORIGINS=http://localhost:5175

# --- Auth / session ---
# Cookie name carrying the workspace session id.
SESSION_COOKIE_NAME=workspace_session
# SameSite policy. "lax" is correct when workspace-web and workspace-api share
# an eTLD+1 (e.g. workspace.dempsey.agency + workspace-api.dempsey.agency).
# Use "none" only if the two sites do not share an eTLD+1; then Secure is required.
SESSION_COOKIE_SAMESITE=lax
# Secure cookie flag. Defaults: true in production, false in development.
# Uncomment to override explicitly.
# SESSION_COOKIE_SECURE=true
# Session lifetime in days.
SESSION_TTL_DAYS=14
# Invite lifetime in days.
INVITE_TTL_DAYS=7
# Public URL of workspace-web (used to build invite acceptance links).
# APP_WORKSPACE_URL=https://workspace.dempsey.agency

# --- Admin bootstrap (used only by `npm run bootstrap:admin`) ---
# ADMIN_EMAIL=admin@dempsey.agency
# ADMIN_PASSWORD=change-this-to-a-strong-passphrase
# ADMIN_NAME=Admin
